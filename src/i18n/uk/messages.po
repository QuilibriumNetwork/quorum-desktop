msgstr "Коли хтось згадує роль, яку ви маєте"

#: src/components/modals/SpaceSettingsModal/Account.tsx:307
msgid "When someone mentions you directly"
msgstr "Коли хтось згадує вас безпосередньо"

#: src/components/modals/SpaceSettingsModal/Account.tsx:323
msgid "When someone replies to your messages"
msgstr "Коли хтось відповідає на ваші повідомлення"

#: src/components/modals/ConversationSettingsModal.tsx:223
msgid ""
"When you sign a message, you are confirming that it comes from your key. "
"When you don't sign a message, you have plausible deniability. The default "
"for all conversations can be changed in User Settings."
msgstr ""
